PORT=3000
# Prefer a single DATABASE_URL:
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
DATABASE_URL=

# Or set PG* individually (pg supports these):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=123
PGDATABASE=

# Session settings
SESSION_COOKIE_NAME=sid
SESSION_TTL_DAYS=14
COOKIE_SECURE=false
CSRF_COOKIE_NAME=csrf_token

# Uploads
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_BYTES=5242880

