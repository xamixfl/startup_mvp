PORT=3000
# Prefer a single DATABASE_URL:
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
DATABASE_URL=

# Or set PG* individually (pg supports these):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=123
PGDATABASE=

# Session settings
SESSION_COOKIE_NAME=sid
SESSION_TTL_DAYS=14

# Public app URL used in email links
APP_BASE_URL=http://localhost:3000

# Transactional email
# Primary provider: Resend
# If RESEND_API_KEY and EMAIL_FROM are empty, the server tries SMTP fallback next.
RESEND_API_KEY=
EMAIL_FROM=

# Optional SMTP fallback
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-mailbox@mail.ru
# SMTP_PASS=your-password
# SMTP_FROM=your-mailbox@mail.ru
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Uploads
UPLOAD_DIR=uploads
